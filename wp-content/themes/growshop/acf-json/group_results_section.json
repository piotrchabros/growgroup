{
    "key": "group_results_section",
    "title": "Efekty",
    "fields": [
        {
            "key": "field_rs_image",
            "label": "Obraz sekcji",
            "name": "rs_image",
            "type": "image",
            "return_format": "array",
            "preview_size": "medium",
            "instructions": "Obraz po lewej stronie sekcji"
        },
        {
            "key": "field_rs_overlay_title",
            "label": "Tytuł overlay karty",
            "name": "rs_overlay_title",
            "type": "text",
            "default_value": "Skalujemy Twój biznes"
        },
        {
            "key": "field_rs_overlay_description",
            "label": "Opis overlay karty",
            "name": "rs_overlay_description",
            "type": "text",
            "default_value": "Realne wyniki, które przekładają się na zysk."
        },
        {
            "key": "field_rs_overlay_link_text",
            "label": "Tekst linku overlay",
            "name": "rs_overlay_link_text",
            "type": "text",
            "default_value": "Umów konsultację"
        },
        {
            "key": "field_rs_overlay_link_url",
            "label": "URL linku overlay",
            "name": "rs_overlay_link_url",
            "type": "text",
            "default_value": "#kontakt"
        },
        {
            "key": "field_rs_sub_heading_icon",
            "label": "Ikona sub-heading (klasa FA)",
            "name": "rs_sub_heading_icon",
            "type": "text",
            "default_value": "fa-regular fa-circle-dot"
        },
        {
            "key": "field_rs_sub_heading_text",
            "label": "Sub-heading",
            "name": "rs_sub_heading_text",
            "type": "text",
            "default_value": "Results"
        },
        {
            "key": "field_rs_heading",
            "label": "Nagłówek",
            "name": "rs_heading",
            "type": "text",
            "default_value": "Efekty"
        },
        {
            "key": "field_rs_description",
            "label": "Opis",
            "name": "rs_description",
            "type": "textarea",
            "default_value": "Nie wdrażamy pojedynczych rozwiązań. Budujemy środowisko, które pracuje na wynik.",
            "rows": 3,
            "new_lines": ""
        },
        {
            "key": "field_rs_checklist",
            "label": "Lista korzyści",
            "name": "rs_checklist",
            "type": "repeater",
            "min": 0,
            "max": 10,
            "layout": "block",
            "button_label": "Dodaj korzyść",
            "sub_fields": [
                {
                    "key": "field_rs_checklist_title",
                    "label": "Tytuł",
                    "name": "title",
                    "type": "text",
                    "wrapper": { "width": "30" }
                },
                {
                    "key": "field_rs_checklist_description",
                    "label": "Opis",
                    "name": "description",
                    "type": "textarea",
                    "rows": 2,
                    "wrapper": { "width": "70" }
                }
            ]
        }
    ],
    "location": [
        [
            {
                "param": "block",
                "operator": "==",
                "value": "acf/results-section"
            }
        ]
    ],
    "style": "default",
    "position": "normal",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true,
    "show_in_rest": 0
}
