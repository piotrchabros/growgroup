    "location": [
        [
            {
                "param": "block",
                "operator": "==",
                "value": "acf/tech-stack"
            }
        ]
    ],
    "style": "default",
    "position": "normal",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true,
    "show_in_rest": 0
}
