{
    "key": "group_tech_stack",
    "title": "Technology Stack",
    "fields": [
        {
            "key": "field_ts_heading",
            "label": "Nagłówek",
            "name": "ts_heading",
            "type": "text",
            "default_value": "Technology Stack"
        },
        {
            "key": "field_ts_description",
            "label": "Opis",
            "name": "ts_description",
            "type": "textarea",
            "default_value": "Pracujemy z najlepszymi narzędziami na rynku. Generujemy wzrosty w Twoim sklepie dzięki sprawdzonym technologiom.",
